# Sensitive site config (contains DB passwords, encryption keys)
sites/*/site_config.json
archived/sites/*/site_config.json
sites/common_site_config.json

# Logs
logs/
sites/*/logs/
archived/sites/*/logs/

# PID files
config/pids/

# Claude
.claude/

# Gameplan app (not tracked in this repo)
apps/gameplan/

# Local-only HRMS themes (kept on this machine, not shared)
apps/hrms/hrms/public/css/uichange1.css
apps/hrms/hrms/public/css/uichange2.css
apps/hrms/hrms/public/css/uichange3.css
apps/hrms/hrms/public/css/uichange4.css
apps/hrms/hrms/public/css/uichange5.css
apps/hrms/hrms/public/css/uichange6.css

# Compiled/symlinked assets (generated at runtime)
sites/assets/crm
sites/assets/erpnext
sites/assets/frappe
sites/assets/hrms

# Database backups
sites/*/private/backups/*.sql.gz
sites/*/private/backups/*.sql

# Uploaded public files
sites/*/public/files/*.jpg
sites/*/public/files/*.jpeg
sites/*/public/files/*.png
sites/*/public/files/*.pdf
sites/*/public/files/*.doc
sites/*/public/files/*.docx

# Site runtime/index files
sites/*/indexes/
sites/*/touched_tables.json
sites/*/.test_log

# Backups with credentials
sites/*/private/backups/*site_config_backup*

# Machine-specific bench config (generated per server by bench setup procfile/redis)
Procfile
config/redis_cache.conf
config/redis_queue.conf
config/redis_cache.acl
config/redis_queue.acl

# Python virtual environment (rebuilt per server with bench setup env)
env/

# Python cache
__pycache__/
*.pyc
*.pyo

# Node modules
node_modules/

# Build output
dist/
build/

# OS files
.DS_Store
Thumbs.db
apps/erpnext/erpnext/patches/v16_0/*.Identifier

# Site lock files and uploaded calendar invites
sites/*/locks/
sites/*/private/files/*.ics
.claude/
